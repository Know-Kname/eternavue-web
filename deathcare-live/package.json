    "graphql-request": "^7.1.0",
    "lucide-react": "^0.400.0",
    "next": "^15.5.0",
    "next-themes": "^0.4.0",
    "nuqs": "^2.4.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
