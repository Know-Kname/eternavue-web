# ── WordPress / WPGraphQL ──────────────────────────────────────────────────────
# Omit to use mock data (the app is fully functional without WordPress)
NEXT_PUBLIC_WP_GRAPHQL_URL=https://your-wordpress.com/graphql
REVALIDATION_SECRET=your-revalidation-secret

# ── Typesense ──────────────────────────────────────────────────────────────────
TYPESENSE_HOST=localhost
TYPESENSE_PORT=8108
TYPESENSE_PROTOCOL=http
TYPESENSE_API_KEY=your-admin-key
NEXT_PUBLIC_TYPESENSE_SEARCH_KEY=your-search-only-key

# ── Supabase ──────────────────────────────────────────────────────────────────
# Omit to use mock community data
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── Clerk (auth) ───────────────────────────────────────────────────────────────
# Omit to skip auth enforcement (public read-only mode)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...

# ── LegiScan (legislative data) ───────────────────────────────────────────────
# Omit to use mock bill data; free tier: 30k calls/month
LEGISCAN_API_KEY=your-legiscan-api-key

# ── Gemini (AI briefings) ────────────────────────────────────────────────────
# Powers AI-assisted weekly digest summaries and bill analysis
# Model: gemini-2.5-flash (default) or gemini-2.5-pro for highest quality
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.5-flash

# ── Resend (email) ────────────────────────────────────────────────────────────
RESEND_API_KEY=re_...

# ── Cloudinary (media) ───────────────────────────────────────────────────────
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=your-cloud-name
NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET=your-upload-preset
